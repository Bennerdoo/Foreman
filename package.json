{
  "name": "foreman",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/api",
    "packages/dashboard"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/api\" \"npm run dev --workspace=packages/dashboard\"",
    "build": "npm run build --workspace=packages/core && npm run build --workspace=packages/api && npm run build --workspace=packages/dashboard",
    "benchmark": "npm run benchmark --workspace=packages/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
